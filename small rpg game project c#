using System;
using System.Diagnostics;
using System.Collections.Generic;
using System.Threading;

namespace ConsoleApp13
{
    internal class Program
    {
        const char Empty = '░';
        const char Player = 'P';
        const char wall = '#';
        const char EnemyChar = 'E';

        static int width = 40;
        static int height = 20;

        static int playerHP = 10;

        static char[,] map = new char[width, height];
        static Random rnd = new Random();

        static void Main(string[] args)
        {
            List<Enemy> enemies = new List<Enemy>
            {
                new Enemy { x = 5, y = 5, HP = 3 },
                new Enemy { x = 10, y = 12, HP = 3 },
                new Enemy { x = 20, y = 7, HP = 3 }
            };

            Stopwatch attackTimer = new Stopwatch();
            attackTimer.Start();

            Console.SetWindowSize(80, 50);
            Console.SetBufferSize(80, 50);
            Console.CursorVisible = false;

            int x = width / 2;
            int y = height / 2;
            int prevX = x;
            int prevY = y;

            InitializeMap(x, y);
            DrawMap();

            DrawEntity(x, y, Player);
            foreach (var enemy in enemies)
                DrawEntity(enemy.x, enemy.y, EnemyChar);

            while (true)
            {
                
                ConsoleKeyInfo keyInfo = new ConsoleKeyInfo();
                if (Console.KeyAvailable)
                {
                    keyInfo = Console.ReadKey(true);
                    while (Console.KeyAvailable) 
                        Console.ReadKey(true);

                    Player_Movement(keyInfo, ref x, ref y, ref prevX, ref prevY);

                    if (keyInfo.Key == ConsoleKey.Spacebar && attackTimer.ElapsedMilliseconds > 400)
                    {
                        foreach (var enemy in enemies)
                        {
                            int dx = x - enemy.x;
                            int dy = y - enemy.y;

                            if (Math.Abs(dx) + Math.Abs(dy) <= 1)
                                enemy.HP--;
                        }
                        attackTimer.Restart();
                    }
                }

                
                enemies.RemoveAll(e => e.HP <= 0);

                
                foreach (var enemy in enemies)
                    EnemyMovement(enemy, x, y);

                
                foreach (var enemy in enemies)
                {
                    int dx = x - enemy.x;
                    int dy = y - enemy.y;

                    if (Math.Abs(dx) + Math.Abs(dy) <= 1 && attackTimer.ElapsedMilliseconds > 1000)
                    {
                        playerHP--;
                        attackTimer.Restart();

                        Console.SetCursorPosition(0, height + 2);
                        Console.Write($"HP: {playerHP}   ");

                        if (playerHP <= 0)
                        {
                            Console.SetCursorPosition(0, height + 3);
                            Console.WriteLine("Game Over");
                            return;
                        }
                    }
                }

                Thread.Sleep(100);
            }
        }

        static void DrawEntity(int x, int y, char symbol)
        {
            Console.SetCursorPosition(x, height - 1 - y);
            Console.Write(symbol);
        }

        static void EnemyMovement(Enemy enemy, int playerX, int playerY)
        {
            int dx = playerX - enemy.x;
            int dy = playerY - enemy.y;

            int newX = enemy.x;
            int newY = enemy.y;

            if (Math.Abs(dx) + Math.Abs(dy) <= 8)
            {
                if (rnd.Next(2) == 0)
                    newX += Math.Sign(dx);
                else
                    newY += Math.Sign(dy);
            }
            else
            {
                int dir = rnd.Next(4);
                if (dir == 0) newX++;
                if (dir == 1) newX--;
                if (dir == 2) newY++;
                if (dir == 3) newY--;
            }

            newX = Math.Clamp(newX, 0, width - 1);
            newY = Math.Clamp(newY, 0, height - 1);

            if (map[newX, newY] != wall)
            {
                Console.SetCursorPosition(enemy.x, height - 1 - enemy.y);
                Console.Write(map[enemy.x, enemy.y]);

                enemy.x = newX;
                enemy.y = newY;

                DrawEntity(enemy.x, enemy.y, EnemyChar);
            }
        }

        static void Player_Movement(ConsoleKeyInfo key, ref int x, ref int y, ref int prevX, ref int prevY)
        {
            int newX = x;
            int newY = y;

            if (key.Key == ConsoleKey.W) newY++;
            if (key.Key == ConsoleKey.S) newY--;
            if (key.Key == ConsoleKey.A) newX--;
            if (key.Key == ConsoleKey.D) newX++;

            newX = Math.Clamp(newX, 0, width - 1);
            newY = Math.Clamp(newY, 0, height - 1);

            if (map[newX, newY] != wall)
            {
                Console.SetCursorPosition(prevX, height - 1 - prevY);
                Console.Write(map[prevX, prevY]);

                x = newX;
                y = newY;

                DrawEntity(x, y, Player);

                prevX = x;
                prevY = y;
            }
        }

        static void InitializeMap(int playerX, int playerY)
        {
            for (int x = 0; x < width; x++)
            {
                for (int y = 0; y < height; y++)
                    map[x, y] = rnd.NextDouble() < 0.1 ? wall : Empty;
            }

            for (int x = 0; x < width; x++)
            {
                map[x, 0] = wall;
                map[x, height - 1] = wall;
            }

            for (int y = 0; y < height; y++)
            {
                map[0, y] = wall;
                map[width - 1, y] = wall;
            }

            map[playerX, playerY] = Empty;
        }

        static void DrawMap()
        {
            for (int y = height - 1; y >= 0; y--)
            {
                for (int x = 0; x < width; x++)
                    Console.Write(map[x, y]);
                Console.WriteLine();
            }
        }
    }

    class Enemy
    {
        public int x;
        public int y;
        public int HP;
    }
}
